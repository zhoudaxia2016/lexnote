{
  "manifest_version": 3,
  "name": "PDF Vocab - 生词本",
  "version": "2.0",
  "description": "Reading any PDF in Chrome → right-click unknown word → AI translates → saves to WPS table",
  "permissions": [
    "contextMenus",
    "storage",
    "sidePanel",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
